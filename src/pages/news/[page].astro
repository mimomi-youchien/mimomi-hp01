---
import Layout from "../../layouts/Layout.astro";
import PageKv from "../../components/PageKv.astro";
import BlogCard from "../../components/BlogCard.astro";
import Cta from "../../components/Cta.astro";
import type { GetStaticPathsOptions } from 'astro';

import { getNews } from "../../library/microcms";

const { page } = Astro.props;

// 全件取得（ソート処理のため）
const allPosts = await getNews({
  fields: ["id", "title", "thumbnail", "thumbnailAlt", "category", "publishedAt", "customDate"],
  limit: 100,
});

// ソート処理（customDate優先）
const sortedPosts = allPosts.contents.sort((a, b) => {
  const dateA = new Date(a.customDate || a.publishedAt);
  const dateB = new Date(b.customDate || b.publishedAt);
  return dateB.getTime() - dateA.getTime(); // 新しい順
});

// ページごとの投稿を取り出す
const postsPerPage = 8;
const start = (page.currentPage - 1) * postsPerPage;
const end = start + postsPerPage;
const posts = sortedPosts.slice(start, end);

// 動的ルートの生成
export const getStaticPaths = async ({ paginate }: GetStaticPathsOptions) => {
  const allNews = await getNews({
    fields: ["id", "title", "thumbnail", "thumbnailAlt", "category", "publishedAt", "customDate"],
    limit: 100,
  });

  // 同様にソート
  const sorted = allNews.contents.sort((a, b) => {
    const dateA = new Date(a.customDate || a.publishedAt);
    const dateB = new Date(b.customDate || b.publishedAt);
    return dateB.getTime() - dateA.getTime();
  });

  return paginate(sorted, { pageSize: 8 });
};
---

<Layout
  subTitle="お知らせ一覧"
  ogType="website"
  description="自然いっぱいの広い敷地でのびのび遊び、学ぶ「みもみ幼稚園」。園からのお知らせや日々の様子、行事のご案内などをブログ形式で発信中。"
  noIndex="true"
>
  <!-- news-list-kv -->
  <div class="news-list-kv">
    <PageKv
      title="お知らせ"
      imageSrcSp="/assets/images/kv/page-kv/pic-kv-news-sp@2x.webp"
      imageSrcPc="/assets/images/kv/page-kv/pic-kv-news-pc@2x.webp"
    />
  </div><!-- /.news-list-kv -->

  <main class="news-list-main l-section-body">
    <div class="l-container-s">
      <ul class="news-list-list">
        {
          posts.map((item) => (
            <li class="news-list-item">
              <BlogCard
                id={item.id}
                title={item.title}
                thumbnail={item.thumbnail?.url}
                thumbnailAlt={item.thumbnailAlt}
                customDate={item.customDate}
                publishedAt={item.publishedAt}
                category={item.category}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </main>

  <div class="news-list-cta">
    <Cta />
  </div><!-- /.news-list-cta -->
</Layout>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .news-list-kv {
    padding-top: 20px;
    margin-top: 48px;
  }

  .news-list-list {
    display: grid;
    gap: 20px;
    margin-top: 30px;
  }

  .news-list-item {
    &:not(:last-child) {
      padding-bottom: 20px;
      border-bottom: 1px solid;
    }
  }

  .news-list-cta {
    margin-top: 60px;
  }


  @include mq() {
    .news-list-kv {
      margin-top: 100px;
    }

    .news-list-list {
      margin-top: 40px;
    }

    .news-list-cta {
      margin-top: 120px;
    }
  }
</style>
