---
import Layout from "../layouts/Layout.astro";
import PageKv from "../components/PageKv.astro";
import LifeTimetable from "../components/page-life/LifeTimetable.astro";

import Cta from "../components/Cta.astro";
---

<Layout
  subTitle="園の生活"
  pgType="website"
  description="⚫︎⚫︎⚫︎⚫︎⚫︎⚫︎⚫︎⚫︎⚫︎⚫︎⚫"
  noIndex="true"
>

  <div class="life">
    <!-- life-kv -->
    <div class="life-kv">
      <PageKv
        title="園の生活"
        imageSrcSp="/assets/images/kv/page-kv/pic-kv-life-sp@2x.png"
        imageSrcPc="/assets/images/kv/page-kv/pic-kv-life-pc@2x.png"
      />
    </div><!-- /.life-kv -->

    <main class="life-main l-section-body">
      <div class="l-container-s">

        <!-- life-timetable -->
        <div class="life-timetable js-load-fade-in">
          <LifeTimetable />
        </div><!-- /.life-timetable -->





        <!-- about-philosophy -->
        <div class="about-philosophy js-fade-in">
          <!-- <AboutPhilosophy /> -->
        </div><!-- /.about-philosophy -->

        <!-- about-kyushoku -->
        <div class="about-kyushoku js-fade-in" id="kyushoku">
          <!-- <AboutKyushoku /> -->
        </div><!-- /.about-kyushoku -->

        <!-- about-bus -->
        <div class="about-bus js-fade-in" id="bus">
          <!-- <AboutBus /> -->
        </div><!-- /.about-bus -->

        <!-- about-safety -->
        <div class="about-safety js-fade-in" id="safety">
          <!-- <AboutSafety /> -->
        </div><!-- /.about-safety -->

        <!-- about-facility -->
        <div class="about-facility js-fade-in" id="facility">
          <!-- <AboutFacility /> -->
        </div><!-- /.about-facility -->
      </div><!-- /.l-container-s -->
    </main>

    <div class="life-cta">
      <Cta />
    </div><!-- /.life-cta -->
  </div><!-- /.life -->
</Layout>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .life {
    overflow: hidden;
  }

  .life-cta {
    margin-top: 60px;
  }

  @include mq() {
    .life-cta {
      margin-top: 120px;
    }
  }

  // life-kv
  .life-kv {
    padding-top: 20px;
    margin-top: 48px;

    @include mq() {
      margin-top: 100px;
    }
  }

</style>
