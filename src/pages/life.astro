---
import Layout from "../layouts/Layout.astro";
import PageKv from "../components/PageKv.astro";
import AboutLead from "../components/page-about/AboutLead.astro";
import AboutPhilosophy from "../components/page-about/AboutPhilosophy.astro";
import AboutKyushoku from "../components/page-about/AboutKyushoku.astro";
import AboutBus from "../components/page-about/AboutBus.astro";
import AboutSafety from "../components/page-about/AboutSafety.astro";
import AboutFacility from "../components/page-about/AboutFacility.astro";
import Cta from "../components/Cta.astro";
---

<Layout
  subTitle="ењ’гЃ®з”џжґ»"
  pgType="website"
  description="вљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«пёЋвљ«"
  noIndex="true"
>

  <div class="life">
    <!-- life-kv -->
    <div class="life-kv">
      <PageKv
        title="ењ’гЃ®зґ№д»‹"
        imageSrcSp="/assets/images/kv/page-kv/pic-kv-life-sp@2x.png"
        imageSrcPc="/assets/images/kv/page-kv/pic-kv-life-pc@2x.png"
      />
    </div><!-- /.life-kv -->

    <main class="life-main l-section-body">
      <div class="l-container-s">

        <!-- life-timetable -->
        <div class="life-timetable js-load-fade-in" id="timetable">
          <AboutLead />
        </div><!-- /.life-timetable -->

        <!-- about-philosophy -->
        <div class="about-philosophy js-fade-in">
          <AboutPhilosophy />
        </div><!-- /.about-philosophy -->

        <!-- about-kyushoku -->
        <div class="about-kyushoku js-fade-in" id="kyushoku">
          <AboutKyushoku />
        </div><!-- /.about-kyushoku -->

        <!-- about-bus -->
        <div class="about-bus js-fade-in" id="bus">
          <AboutBus />
        </div><!-- /.about-bus -->

        <!-- about-safety -->
        <div class="about-safety js-fade-in" id="safety">
          <AboutSafety />
        </div><!-- /.about-safety -->

        <!-- about-facility -->
        <div class="about-facility js-fade-in" id="facility">
          <AboutFacility />
        </div><!-- /.about-facility -->
      </div><!-- /.l-container-s -->
    </main>

    <div class="life-cta">
      <Cta />
    </div><!-- /.life-cta -->
  </div><!-- /.life -->
</Layout>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .life {
    overflow: hidden;
  }

  .life-cta {
    margin-top: 60px;
  }

  @include mq() {
    .life-cta {
      margin-top: 120px;
    }
  }

  // life-kv
  .life-kv {
    padding-top: 20px;
    margin-top: 48px;

    @include mq() {
      margin-top: 100px;
    }
  }

  // about-kyushoku
  .about-kyushoku {
    position: relative;

    &::before {
      content: "";
      width: 800px;
      height: 1280px;
      background-image: url(/assets/images/about/page-about/kyushoku/bg-about-kyushoku-sp@2x.svg);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      position: absolute;
      top: -172px;
      left: 50%;
      z-index: -1;
      translate: -50%;

      @include mq() {
        width: 2000px;
        height: 1562px;
        background-image: url(/assets/images/about/page-about/kyushoku/bg-about-kyushoku-pc@2x.svg);
        top: -219px;
      }
    }
  }
</style>
