---
// import "../styles/splide.css";
import Layout from "../layouts/Layout.astro";

import TopKv from "../components/topPage/TopKv.astro";
import TopLead from "../components/topPage/TopLead.astro";
import TopIntroduction from "../components/topPage/TopIntroduction.astro";
import TopLife from "../components/topPage/TopLife.astro";
import TopNews from "../components/topPage/TopNews.astro";
import TopLinks from "../components/topPage/TopLinks.astro";
import TopFaq from "../components/topPage/TopFaq.astro";
import TopDownload from "../components/topPage/TopDownload.astro";
import Cta from "../components/Cta.astro";
---

<Layout
  subTitle="トップページ"
  ogType="website"
  description="所沢市の女性向けヨガ&ピラティス「koyomi yoga pilates」。マタニティ・産後ケアからボディメイクまで多彩なプログラム。少人数制の空間で心と体を整えます。"
>
  <!-- top-kv -->
  <div id="kv">
    <TopKv />
  </div>

  <!-- top-main -->
  <main class="top-main">

    <!-- top-lead -->
    <div id="lead">
      <TopLead />
    </div>

    <!-- top-introduction -->
    <div id="introduction">
      <TopIntroduction />
    </div>

    <!-- top-life -->
    <div id="life">
      <TopLife />
    </div>

    <!-- top-news -->
    <div id="news">
      <TopNews />
    </div>

    <!-- top-links -->
    <div id="links">
      <TopLinks />
    </div>

    <!-- top-faq -->
    <div id="faq">
      <TopFaq />
    </div>

    <!-- top-download -->
    <div id="download">
      <TopDownload />
    </div>

    <!-- top-cta -->
    <div class="top-cta l-section">
      <Cta />
    </div><!-- /.top-cta.l-section -->
  </main>
</Layout>

<style lang="scss">
  @use '../styles/breakpoints' as *;

</style>
