---
import { isAuthenticated } from "../utils/auth";
import { getPassword } from "../library/microcms";

const cookies = Astro.cookies;
const request = Astro.request;

let showError = false;

// POST処理（フォーム送信）
if (request.method === 'POST') {
  const contentType = request.headers.get('content-type') || '';
  if (contentType.includes('application/x-www-form-urlencoded') || contentType.includes('multipart/form-data')) {
    const formData = await request.formData();
    const enteredPassword = formData.get('password')?.toString() ?? '';
    const cmsPasswordData = await getPassword();

    if (enteredPassword === cmsPasswordData.password) {
      cookies.set('auth', enteredPassword, {
        path: '/',
        httpOnly: true,
        secure: import.meta.env.PROD,
        // secure: false, // ローカル環境では false にする
        maxAge: 60 * 60 * 24 * 7, // 1週間
      });

      return new Response(null, {
        status: 302,
        headers: {
          Location: '/limited', // 限定ページのパスに変更可能
        },
      });
    } else {
      return new Response(null, {
        status: 302,
        headers: {
          Location: '/password?error=1',
        },
      });
    }
  }
}

// エラーフラグ取得
const url = new URL(request.url);
showError = url.searchParams.get('error') === '1';
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>パスワード入力｜〇〇幼稚園</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <main>
      <h1>在園児専用ページ ログイン</h1>
      {showError && <p style="color: red;">パスワードが間違っています。</p>}
      <form method="POST">
        <label for="password">パスワードを入力してください：</label><br />
        <input type="password" id="password" name="password" required /><br />
        <button type="submit">ログイン</button>
      </form>
    </main>
  </body>
</html>
