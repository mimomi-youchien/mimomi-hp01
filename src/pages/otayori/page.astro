---
import Layout from "../../layouts/Layout.astro";
import OtayoriKv from "../../components/OtayoriKv.astro"
import Cta from "../../components/Cta.astro";
---

<Layout
  subTitle="保護者さま限定 おたより一覧"
  ogType="website"
  description=""
  noIndex="true"
>
  <!-- otayori-list-kv -->
  <div class="otayori-list-kv">
    <OtayoriKv />
  </div><!-- /.otayori-list-kv -->

  <main class="otayori-list-main l-section-body">
    <div class="l-container-s">
      
    </div>
  </main>

  <div class="otayori-list-cta">
    <Cta />
  </div><!-- /.otayori-list-cta -->
</Layout>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .otayori-list-kv {
    padding-top: 20px;
    margin-top: 48px;
  }

  .otayori-list-main {
  }

  .otayori-list-list {
    display: grid;
    gap: 20px;
    margin-top: 30px;
  }

  .otayori-list-item {
    &:not(:last-child) {
      padding-bottom: 20px;
      border-bottom: 1px solid;
    }
  }

  .otayori-list-cta {
    margin-top: 60px;
  }


  @include mq() {
    .otayori-list-kv {
      margin-top: 100px;
    }

    .otayori-list-main {

    }

    .otayori-list-list {
      margin-top: 40px;
    }

    .otayori-list-cta {
      margin-top: 120px;
    }
  }
</style>

