---
import "../styles/style.scss";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";

const logo = "/assets/images/global/logo.svg";
const logoAlt = "学校法人飯生学園 みもみ幼稚園";
const {
  title = "自然豊かな環境でのびのびと成長する習志野市の幼稚園｜みもみ幼稚園",
  ogType = "website",
  ogTitle = title,
  description = "京成実籾駅徒歩3分のみもみ幼稚園は、自然に囲まれた広い敷地でのびのび遊び、学べる環境です。自由と自立を育む教育を行っています。習志野市・船橋市・八千代市・千葉市からもアクセス良好です。見学も随時受付中です。",
  ogDescription = description,
  ogImage = "https://www.mimomi-youchien.com/ogp.webp",
  noIndex = false,
  jsonLd = ""
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>

    { noIndex && <meta name="robots" content="noindex, nofollow" /> }

    <!-- favicon -->
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" href="/android-chrome-256x256.png">

    <!-- ogp -->
    <meta property="og:site_name" content="学校法人飯生学園 みもみ幼稚園">
    <meta property="og:url" content={`https://www.mimomi-youchien.com${Astro.url.pathname}`} />
    <meta property="og:type" content={ogType}>
    <meta property="og:title" content={ogTitle}>
    <meta property="og:description" content={ogDescription}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:locale" content="ja_JP">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:description" content={ogDescription}>
    <meta name="twitter:image:src" content={ogImage}>

    <!-- destyle.css -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/destyle.css@4.0.0/destyle.min.css">

    <!-- 構造化データ -->
    {jsonLd && (
      <script type="application/ld+json" set:html={jsonLd}></script>
    )}

    <!-- Netlify Identity -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
  </head>

  <body id="body">
    <Header
      logo={logo}
      logoAlt={logoAlt}
    />

    <slot />

    <Footer
      logo={logo}
    />

    <script src="/assets/js/fadeInAnimation.js" defer></script>

    <!-- Netlify Identityの初期化とログインチェック -->
    <script defer>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user) => {
          const isOtayori = window.location.pathname.startsWith("/otayori/");
          const hasInviteToken = window.location.hash.includes("invite_token=");

          // 未ログインかつ招待トークン付き → モーダルを開く
          if (!user && hasInviteToken) {
            window.netlifyIdentity.on("login", () => {
              window.location.href = "/otayori/1"; // 任意：ログイン後の遷移先
            });
            window.netlifyIdentity.open(); // モーダル表示
          }

          // /otayori/ 配下へのアクセスで未ログイン → ログイン確認ページへリダイレクト
          if (!user && isOtayori && !hasInviteToken) {
            window.location.href = "/check-login/";
          }
        });

        window.netlifyIdentity.init();
      }
    </script>
  </body>
</html>
