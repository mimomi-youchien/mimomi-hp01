              <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-01-pc@2x.jpg" alt="" loading="lazy" decoding="async" width="275" height="310">
            </div><!-- /.life-annual-event-image-pc-left -->
