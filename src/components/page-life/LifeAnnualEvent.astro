---
import SectionTitle from "../SectionTitle.astro";
---

<section class="life-annual-event l-section">
  <div class="life-annual-event-title">
    <SectionTitle
      title1="年間行事"
    />
  </div>
  <div class="life-annual-event-content l-section-body">
    <ol class="life-annual-event-list">
      <li class="life-annual-event-item">
        <h3 class="life-annual-event-title-lv3">1学期</h3>
        <p class="life-annual-event-content-text">入園式・こいのぼり集会(年長さんが作った大きなこいのぼりを園庭に飾ります)・参観日・さつまいもの苗植え・じゃがいも堀り・プール開き・七夕集会・年長お楽しみ会(すいか割り・盆踊り・出張プラネタリウム)・卒園1,２年生の同窓会</p>
        <div class="life-annual-event-image">
          <!-- sp -->
          <div class="life-annual-event-image-sp">
            <div class="life-annual-event-image-sp-top">
              <div class="life-annual-event-image-sp-left">
                <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-01-sp@2x.jpg" alt="" loading="lazy" decoding="async" width="210" height="301">
              </div><!-- /.life-annual-event-image-sp-left -->
              <div class="life-annual-event-image-sp-right">
                <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-02@2x.jpg" alt="" loading="lazy" decoding="async" width="155" height="145">
                <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-03@2x.jpg" alt="" loading="lazy" decoding="async" width="155" height="145">
                <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-04@2x.jpg" alt="" loading="lazy" decoding="async" width="155" height="145">
              </div><!-- /.life-annual-event-image-sp-right -->
            </div><!-- /.life-annual-event-image-sp-top -->
            <div class="life-annual-event-image-sp-bottom">
              <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-05@2x.jpg" alt="" loading="lazy" decoding="async" width="155" height="145">
              <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-06@2x.jpg" alt="" loading="lazy" decoding="async" width="155" height="145">
              <img src="/public/assets/images/life/page-life/annual-event/pic-life-annual-event-1st-07@2x.jpg" alt="" loading="lazy" decoding="async" width="155" height="145">
