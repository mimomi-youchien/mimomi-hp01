---
import ButtonCta from "../button/ButtonCta.astro";
const { logo } = Astro.props;
---

<!-- footer -->
<footer class="footer">
  <div class="footer-container l-container">
    <div class="footer-info">
      <div class="footer-logo">
        <img src={logo} alt="" loading="lazy" decoding="async" width="152" height="33">
      </div><!-- /.footer-logo -->
      <div class="footer-location">
        <p class="footer-address">〒275-0002&emsp;千葉県習志野市実籾3-13-15</p>
        <p class="footer-access">京成実籾駅より徒歩3分</p>
      </div><!-- /.footer-location -->
      <div class="footer-tel">
        <a href="tel:047-473-4724">047-473-4724</a>
      </div><!-- /.footer-tel -->
      <div class="footer-line">
        <p class="footer-line-text">
          <span>みもみ幼稚園公式LINEにて最新情報を配信しています！</span>
          <span>採用情報はリクルート専用LINEをご登録ください。</span>
        </p>
        <ul class="footer-line-link">
          <li class="footer-line-item">
            <ButtonCta />
          </li>
          <li class="footer-line-item">
            <ButtonCta
            ctaText="リクルート専用"
            ctaClass="c-button-cta c-button-cta--recruitment"
            ctaHref="https://lin.ee/qD9ric4"
            />
          </li>
        </ul>
      </div><!-- /.footer-line -->
    </div><!-- /.footer-info -->
    <div class="footer-privacy-policy">
      <a href="">プライバシーポリシー</a>
    </div><!-- /.footer-privacy-policy -->
    <div class="footer-copyright footer-copyright--sp">
      <small aria-label="著作権 2024 学校法人飯生学園みもみ幼稚園">&copy;2024 学校法人飯生学園みもみ幼稚園 All Rights Reserved.</small>
    </div><!-- /.footer-copyright -->
    <nav class="footer-nav" aria-label="フッターナビゲーション">
      <div class="footer-nav-list">
        <div class="footer-nav-group">
          <div class="footer-nav-item">
            <a href="/">ホーム</a>
            <ul class="footer-sub-menus">
              <li class="footer-sub-menus-item">
                <a href="/#faq">よくある質問</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="/#download">各種ダウンロード</a>
              </li>
            </ul>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="" class="u-disabled">園の紹介</a>
            <ul class="footer-sub-menus">
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">教育方針</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">自園給食</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">バス送迎</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">安心・安全への取り組み</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">施設紹介</a>
              </li>
            </ul>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="" class="u-disabled">園の生活</a>
            <ul class="footer-sub-menus">
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">園の一日</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">みもみ保育</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">年間行事</a>
              </li>
              <li class="footer-sub-menus-item">
                <a href="" class="u-disabled">預かり保育</a>
              </li>
            </ul>
          </div><!-- /.footer-nav-item -->
        </div><!-- /.footer-nav-group -->
        <div class="footer-nav-group">
          <div class="footer-nav-item">
            <a href="" class="u-disabled">入園案内</a>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="/blog/blog-list">お知らせ</a>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="" class="u-disabled">園の概要</a>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="" class="u-disabled">よくある質問</a>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="" class="u-disabled">保護者さま専用ページ<span>「おたより」</span></a>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="/mi-shuen-ji">未就園児親子教室<span>について</span></a>
          </div><!-- /.footer-nav-item -->
          <div class="footer-nav-item">
            <a href="" class="u-disabled">プライバシーポリシー</a>
          </div><!-- /.footer-nav-item -->
        </div><!-- /.footer-nav-group -->
      </div><!-- /.footer-nav-list -->
    </nav>
  </div><!-- /.footer-container.l-container -->
  <div class="l-container">
    <div class="footer-copyright footer-copyright--pc">
      <small aria-label="著作権 2024 学校法人飯生学園みもみ幼稚園">&copy;2024 学校法人飯生学園みもみ幼稚園 All Rights Reserved.</small>
    </div><!-- /.footer-copyright -->
  </div><!-- /.l-container -->
</footer><!-- /.footer -->

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .footer {
    padding-top: 40px;
    height: 325px;
    margin-top: 60px;
    font-size: 10px;
    line-height: 1.5;
    position: relative;
    overflow: hidden;

    &::before {
      content: "";
      width: 800px;
      height: 325px;
      background-image: url(/public/assets/images/global/bg-footer-sp@2x.webp);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      position: absolute;
      top: 0;
      left: 50%;
      z-index: -1;
      translate: -50%;
    }
  }

  .footer-container {
    width: fit-content;
  }

  .footer-logo {
    max-width: 84px;
  }

  .footer-location {
    margin-top: 10px;
  }

  .footer-tel {
    width: fit-content;

    a {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 5px 0;
      font-size: 12px;
      font-weight: 700;

      &::before {
        content: "";
        width: 12px;
        height: 12px;
        background-image: url(/public/assets/images/global/icon-tel.svg);
        background-repeat: no-repeat;
        background-size: contain;
        background-position: center center;
        filter: invert(38%) sepia(35%) saturate(640%) hue-rotate(347deg) brightness(92%) contrast(86%);
      }
    }
  }

  .footer-line {
    margin-top: 5px;
  }

  .footer-line-text {
    display: grid;
  }

  .footer-line-link {
    display: flex;
    gap: 10px;
    margin-top: 5px;
  }

  .footer-privacy-policy {
    a {
      display: block;
      width: fit-content;
      padding: 5px 0;
      margin-top: 5px;
    }
  }

  .footer-nav {
    display: none;
  }

  .footer-copyright {
    &--pc {
      display: none;
    }

    small {
      font-size: 10px;
    }
  }

  @include mq() {
    .footer {
      padding-top: 60px;
      margin-top: 120px;
      height: 480px;

      &::before {
        width: 1200px;
        height: 480px;
        background-image: url(/public/assets/images/global/bg-footer-tb@2x.png);
      }
    }

    .footer-container {
      width: 100%;
      padding: 0 calc(80 / 768 * 100vw);
    }

    .footer-info {
      font-size: 12px;
    }

    .footer-logo {
      max-width: 172px;
    }

    .footer-location {
      margin-top: 20px;
    }

    .footer-tel {
      a {
        gap: 10px;
        font-size: 16px;

        &::before {
          width: 16px;
          height: 16px;
        }
      }
    }

    .footer-line {
      margin-top: 15px;
    }

    .footer-line-link {
      gap: 24px;
    }
  }

  @media screen and (min-width: 1025px) {
    .footer {
      padding-top: 133px;
      height: 590px;

      &::before {
        width: 2000px;
        height: 590px;
        background-image: url(/public/assets/images/global/bg-footer-pc@2x.webp);
      }
    }

    .footer-container {
      display: flex;
      justify-content: space-between;
      width: 100%;
      padding: 0 40px;
    }

    .footer-info {
      // font-size: 12px;
      margin-top: 5px;
    }

    .footer-logo {
      // max-width: 172px;
    }

    .footer-location {
      // margin-top: 20px;
    }

    .footer-tel {
      // タブレット横向き(1024px)まで電話発信有効
      @media screen and (min-width: 1025px) {
        text-decoration: none;
        pointer-events: none;
        cursor: default;
      }
    }

    .footer-line {
      // margin-top: 15px;
    }

    .footer-line-link {
      gap: 20px;
    }

    .footer-line-item {

    }

    .footer-privacy-policy {
      display: none;
    }

    .footer-nav {
      display: block;
    }

    .footer-nav-list {
      display: flex;
      gap: 40px;
      font-size: 14px;

      a {
        display: block;
        padding: 5px 0;
      }
    }

    .footer-nav-group {
      &:first-child {
        display: flex;
        gap: 40px;
      }

      &:last-child {
        display: grid;
        gap: 10px;
      }
    }

    .footer-nav-item {
      & > a {
        font-weight: 700;
      }

      a span {
        display: none;

        @media screen and (min-width: 1101px) {
          display: inline;
        }
      }
    }

    .footer-sub-menus {
      display: grid;
      gap: 10px;
      margin-top: 10px;
    }

    .footer-sub-menus-item {

    }

    .footer-copyright {
      &--sp {
        display: none;
      }

      &--pc {
        display: block;
        margin-top: 15px;
        text-align: right;
      }

      small {
        font-size: 10px;
      }
    }
  }

  @media (any-hover: hover) {
    .footer-nav-item a,
    .footer-sub-menus-item a {
      transition: opacity .3s ease;

      &:hover {
        opacity: .8;
      }
    }
  }
</style>
