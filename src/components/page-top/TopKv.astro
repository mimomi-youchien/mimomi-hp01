---
import { getNews } from "../../library/microcms";
import { formatNewsDate, toMachineDate } from "../../utils/formatDate";

// 多めに取得し、カテゴリーでフィルタしてからソート
const response = await getNews({ limit: 100 });

const allowedCategories = ["ご連絡", "募集案内"];

const newsList = response.contents
  .filter(item => item.category.some(cat => allowedCategories.includes(cat)))
  .sort((a, b) => {
    const dateA = new Date(a.customDate || a.publishedAt);
    const dateB = new Date(b.customDate || b.publishedAt);
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 2); // 上位2件のみ
---

<div class="top-kv">
  <div class="top-kv-bg">
    <picture>
      <source media="(max-width: 767px)" srcset="/assets/images/kv/bg-kv-sp@2x.webp">
      <source media="(min-width: 768px)" srcset="/assets/images/kv/bg-kv-pc@2x.webp">
      <img src="/assets/images/kv/bg-kv-sp@2x.webp" alt="木の枝と葉を使ってバーベキューごっこをする3歳児2人（アスレチック広場）" loading="eager" decoding="async" width="375" height="555">
    </picture>
  </div><!-- /.top-kv-bg -->
  <div class="top-kv-news">
    <h2 class="top-kv-news-heading">最新情報</h2>
    <div class="top-kv-news-wrapper">
      <ul class="top-kv-news-list">
        {newsList.map((item) => (
          <li class="top-kv-news-item">
            <a href={`/news/${item.id}`} class="top-kv-news-link">
              <div class="top-kv-news-inner">
                <span class="top-kv-news-head">
                  <time datetime={toMachineDate(item.customDate || item.publishedAt)} class="top-kv-news-date">
                    {formatNewsDate(item.customDate || item.publishedAt)}
                  </time>
                  <span class="top-kv-news-category">{item.category}</span>
                </span>
                <p class="top-kv-news-title">{item.title}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div><!-- /.top-kv-news-wrapper -->
  </div><!-- /.top-kv-news -->
</div><!-- /.top-kv -->

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .top-kv {
    margin-top: 48px;
  }

  .top-kv-bg {
    width: 100%;
    max-width: 480px;
    margin: auto;
  }

  .top-kv-news {
    display: flex;
    flex-direction: column;
    width: calc(320 var(--vw-sp));
    max-width: 480px;
    padding: 9px 20px 0;
    border-radius: 10px;
    border: 1px solid;
    margin: 19px auto 0;
    background-color: #fffefb;
  }

  .top-kv-news-heading {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.875;
  }

  .top-kv-news-list {
  }

  .top-kv-news-item {
    &:not(:last-child) {
      border-bottom: 1px solid;
    }
  }

  .top-kv-news-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 10px 0;

    &::after {
      content: "";
      flex-shrink: 0;
      width: 12px;
      height: 10px;
      background-image: url(/assets/images/global/icon-arrow-right.svg);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      filter: invert(34%) sepia(63%) saturate(339%) hue-rotate(347deg) brightness(99%) contrast(93%);
    }
  }

  .top-kv-news-inner {

  }

  .top-kv-news-head {
    display: flex;
    align-items: center;
    gap: 10px;
    line-height: 1.5;
  }

  .top-kv-news-date {
    font-size: 10px;
    font-weight: 700;
  }

  .top-kv-news-category {
    padding: 0 10px;
    border-radius: 3px;
    border: 1px solid;
    font-size: 12px;
  }

  .top-kv-news-title {
    margin-top: 10px;
    font-weight: 700;
    line-height: 1.2;
    text-align: justify;
  }

  @include mq() {
    .top-kv {
      margin-top: 100px;
      position: relative;
    }

    .top-kv-bg {
      width: 100%;
      max-width: 1280px;
      margin: auto;
    }

    .top-kv-news {
      flex-direction: row;
      gap: 0;
      width: clamp(740px, calc(763 / 1110 * 100vw), 763px);
      width: clamp(700px, calc(763 / 1110 * 100vw), 763px);
      max-width: initial;
      padding: 10px 24px 6px;
      margin: 0;
      position: absolute;
      top: calc(580 / 1280 * 100vw);
      left: 50%;
      z-index: 10;
      translate: -50%;

      @media screen and (min-width: 1110px) {
        width: 763px;
        padding: 10px 37px 6px;
        left: calc(50% - min(170px, calc(170 / 1280 * 100vw)));
      }

      @media screen and (min-width: 1280px) {
        width: 763px;
        top: 580px;
        left: calc(50% - 170px);
      }
    }

    .top-kv-news-heading {
      flex: 0 0 calc(80px + 38px);
      margin-top: 10px;
      font-size: 20px;
      line-height: 1.5;
    }

    .top-kv-news-list {
      gap: 10px;
      // width: 570px;
    }

    .top-kv-news-item {
      &:not(:last-child) {
        // padding-bottom: 10px;
      }
    }

    .top-kv-news-link {
      gap: 16px;
      font-size: 14px;

      @media screen and (min-width: 1110px) {
        gap: 20px;
      }

      &::after {
        width: 14px;
        height: 12px;
      }
    }

    .top-kv-news-inner {
      display: flex;
      align-items: center;
      gap: 35px;
    }

    .top-kv-news-head {
      flex: 0 0 180px;
      gap: 35px;
    }

    .top-kv-news-category {
      padding: 0 9px;
    }

    .top-kv-news-title {
      flex: 0 0 clamp(290px, calc(328 / 1110 * 100vw), 328px);
      margin-top: 0;

      @media screen and (min-width: 1110px) {
        flex: 0 0 328px;
      }
    }
  }

  @media (any-hover: hover) {
    .top-kv-news-link {
      transition: color .3s ease;

      &:hover {
        color: var(--color-baby-pink);

        &::after {
          filter: invert(97%) sepia(91%) saturate(6024%) hue-rotate(294deg) brightness(100%) contrast(96%);
        }
      }

      &::after {
        transition: filter .3s ease;
      }
    }
  }
</style>
