---
import SectionTitle from "../SectionTitle.astro";
import BlogCard from "../BlogCard.astro";
import ButtonLink from "../button/ButtonLink.astro";
---

<section class="top-news">
  <div class="top-news-container l-container-s">
    <div class="top-news-title">
      <SectionTitle
        title1="お知らせ"
      />
    </div><!-- /.top-news-title -->
    <p class="top-news-lead">園児の日々の様子や<br class="u-no-pc">イベントごとをお届けしています！</p>
    <ul class="top-news-list">
      <!-- 未就園児教室のご案内
令和7年度 未就園児イベントのお知らせ
ホームページをリニューアルしました！ -->
      <li class="top-news-item">
        <BlogCard
          blogTitle="未就園児教室のご案内"
          blogHref="/blog/mi-shuen-ji-class/"
          blogCategory="募集案内"
          blogDatetime="2025-05-01"
          blogDate="2025.05.01"
          blogSrc="/assets/images/blog/pic-blog-thumbnail-mi-shuen-ji-class@2x.jpg"
          blogAlt=""
        />
      </li>
      <li class="top-news-item">
        <BlogCard
          blogTitle="令和7年度 未就園児イベントのお知らせ"
          blogHref="/blog/mi-shuen-ji-events/"
          blogCategory="募集案内"
          blogDatetime="2025-05-01"
          blogDate="2025.05.01"
          blogSrc="/assets/images/blog/pic-blog-thumbnail-mi-shuen-ji-events.jpg"
          blogAlt=""
        />
      </li>
      <li class="top-news-item">
        <BlogCard
          blogTitle="ホームページをリニューアルしました！"
          blogHref="/blog/site-renewal"
          blogCategory="お知らせ"
          blogDatetime="2025-05-01"
          blogDate="2025.05.01"
          blogSrc="/assets/images/blog/pic-blog-thumbnail-site-renewal.jpg"
          blogAlt=""
        />
      </li>
    </ul>
    <div class="top-introduction-button">
      <ButtonLink
        buttonText="お知らせ一覧を見る"
        ButtonHref="/blog/blog-list/"
      />
    </div><!-- /.top-introduction-button -->
  </div><!-- /.top-news-container.l-container-s -->
</section><!-- /.top-news -->

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .top-news {
    padding: 83px 0 83px;
    margin-top: 37px;
    line-height: 1.5;
    position: relative;
    overflow: hidden;

    &::after {
      content: "";
      width: 800px;
      height: 600px;
      background-image: url(/public/assets/images/news/bg-news-sp.svg);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      position: absolute;
      top: 0;
      left: 50%;
      z-index: -1;
      translate: -50%;
    }
  }

  .top-news-lead {
    margin-top: 10px;
    text-align: center;
  }

  .top-news-list {
    display: grid;
    gap: 20px;
    margin-top: 30px;
  }

  .top-news-item {
    &:not(:last-child) {
      padding-bottom: 20px;
      border-bottom: 1px solid;
    }
  }

  .top-introduction-button {
    margin-top: 30px;
    text-align: right;
  }

  @include mq() {
    .top-news {
      padding: 130px 0 130px;
      margin-top: 110px;

      &::after {
        content: "";
        width: 2000px;
        height: 1000px;
        background-image: url(/public/assets/images/news/bg-news-pc.svg);
      }
    }

    .top-news-list {
      margin-top: 40px;
    }

    .top-introduction-button {
      margin-top: 20px;
    }
  }
</style>
