---
import SectionTitle from "../SectionTitle.astro";
import ButtonLink from "../button/ButtonLink.astro";
---

<section class="top-faq">
  <div class="top-faq-container l-container-s">
    <div class="l-section">
      <div class="top-faq-title">
        <SectionTitle
          title1="よくある質問"
        />
      </div><!-- /.top-faq-title -->
      <ul class="top-faq-list l-section-body">
        <li class="top-faq-item">
          <dl class="top-faq-dl">
            <dt class="top-faq-dt">
              <span class="top-faq-icon" aria-label="質問">q</span>
              <span class="top-faq-question">未就園児教室はありますか？</span>
            </dt>
            <dd class="top-faq-dd">
              <div class="top-faq-wrapper">
                <span class="top-faq-icon" aria-label="回答">a</span>
                <div class="top-faq-answer">
                  <p class="top-faq-paragraph">1歳児教室(リトルぴよちゃん教室)、2歳児教室(ぴよちゃん教室)を5月から翌年3月まで開講しています。</p>
                  <p class="top-faq-paragraph">詳細は「未就園児親子教室について」のページをご覧ください。</p>
                </div><!-- /.top-faq-answer -->
              </div><!-- /.top-faq-wrapper -->
              <a href="#" class="top-faq-link">続きを見る</a>
            </dd>
          </dl>
        </li>
        <li class="top-faq-item">
          <dl class="top-faq-dl">
            <dt class="top-faq-dt">
              <span class="top-faq-icon" aria-label="質問">q</span>
              <span class="top-faq-question">見学はできますか？</span>
            </dt>
            <dd class="top-faq-dd">
              <div class="top-faq-wrapper">
                <span class="top-faq-icon" aria-label="回答">a</span>
                <div class="top-faq-answer">
                  <p class="top-faq-paragraph">幼稚園、未就園児教室はいつでもご見学が可能です。詳しい日程のご確認やお申し込みについては、みもみ幼稚園の公式LINEより承っております。園庭、アスレチック広場(どんぐり広場)でも是非遊んでくださいね。</p>
                </div><!-- /.top-faq-answer -->
              </div><!-- /.top-faq-wrapper -->
            </dd>
          </dl>
        </li>
        <li class="top-faq-item">
          <dl class="top-faq-dl">
            <dt class="top-faq-dt">
              <span class="top-faq-icon" aria-label="質問">q</span>
              <span class="top-faq-question">預かり保育はありますか？</span>
            </dt>
            <dd class="top-faq-dd">
              <div class="top-faq-wrapper">
                <span class="top-faq-icon" aria-label="回答">a</span>
                <div class="top-faq-answer">
                  <p class="top-faq-paragraph">早朝保育(8:00〜9:00)、延長保育(保育後〜18:00)があり、全園児ご利用いただけます。早朝保育は一律200円、延長保育は1時間200円となります。また、春休み、夏休み、冬休みには長期休暇保育(8:00〜18:00)をご利用いただけます。詳細は「預かり保育」のページをご覧ください。</p>
                </div><!-- /.top-faq-answer -->
              </div><!-- /.top-faq-wrapper -->
              <a href="#" class="top-faq-link">続きを見る</a>
            </dd>
          </dl>
        </li>
      </ul>
      <div class="top-faq-button">
        <ButtonLink buttonText="すべての質問を見る" />
      </div><!-- /.top-faq-button -->
    </div><!-- /.l-section -->
  </div><!-- /.top-faq-container.l-container-s -->
</section><!-- /.top-faq -->

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .top-faq {

  }

  .top-faq-container {

  }

  .l-container-s {

  }

  .l-section {

  }

  .top-faq-title {

  }

  .top-faq-list {
    display: grid;
    gap: 20px;
    text-align: justify;
  }

  .l-section-body {

  }

  .top-faq-item {

  }

  .top-faq-dl {

  }

  .top-faq-dt {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 20px 6px;
    border-radius: 10px;
    border: 1px solid;
    background-color: #fff;
    font-weight: 400;
  }

  .top-faq-icon {
    color: var(--color-baby-pink);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .top-faq-question {

  }

  .top-faq-dd {
    padding: 9px 20px 0 21px;
  }

  .top-faq-wrapper {
    display: flex;
    gap: 10px;
  }

  .top-faq-answer {
    margin-top: 3px;
  }

  .top-faq-paragraph {

  }

  .top-faq-link {
    display: inline-block;
    padding-right: 3px;
    border-bottom: 1px solid;
    margin: 3px 0 0 24px;
    font-size: 10px;
    position: relative;

    &::after {
      content: "";
      width: 18px;
      height: 18px;
      background-image: url(/assets/images/faq/icon-faq-arrow-right.svg);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      filter: invert(36%) sepia(10%) saturate(2363%) hue-rotate(347deg) brightness(100%) contrast(81%);
      position: absolute;
      top: 0;
      left: 100%;
    }
  }

  .top-faq-button {
    margin-top: 30px;
    text-align: right;
  }

  @include mq() {
    .top-faq-list {
      gap: 40px;
    }

    .top-faq-item {

    }

    .top-faq-dl {

    }

    .top-faq-dt {
      gap: 20px;
      padding: 11px 50px;
    }

    .top-faq-icon {
      font-size: 20px;
    }

    .top-faq-question {

    }

    .top-faq-dd {
      padding: 17px 90px 0 50px;
    }

    .top-faq-wrapper {
      display: flex;
      gap: 20px;
    }

    .top-faq-answer {
      margin-top: 3px;
    }

    .top-faq-paragraph {

    }

    .top-faq-link {
      padding-right: 7px;
      margin: 8px 0 0 37px;
      font-size: 14px;

      &::after {
        content: "";
        width: 24px;
        height: 24px;
        top: 2px;
      }
    }

    .top-faq-button {
      margin-top: 20px;
    }
  }


</style>
