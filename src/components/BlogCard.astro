---
import { formatNewsDate, toMachineDate } from "../utils/formatDate";
const {
  id,
  title,
  thumbnail,
  thumbnailAlt,
  category,
  customDate,
  publishedAt
} = Astro.props;

// customDate があればそれを使い、なければ publishedAt を使う
const rawDate = customDate ?? publishedAt;

// 日付をパースして整形表示（rawDate があれば）
const formattedDate = formatNewsDate(rawDate);
const machineReadableDate = toMachineDate(rawDate);

// altテキストを設定（デフォルト値を指定）
const altText = thumbnailAlt || "ブログのサムネイル画像";
---

<article class="c-blog-card">
  <a href={`/news/${id}`} class="c-blog-card-link" aria-label={`ブログ記事: ${title}`}>
    <div class="c-blog-card-image">
      <img
        src={`${thumbnail}?fm=webp`}
        alt={altText}
        loading="lazy"
        decoding="async"
        width="250"
        height="160"
      >
    </div><!-- /.c-blog-card-image -->
    <div class="c-blog-card-content">
      <span class="c-blog-card-meta">
        <span class="c-blog-card-category">{category}</span>
        <time class="c-blog-card-date" datetime={machineReadableDate}>{formattedDate}</time>
      </span>
      <p class="c-blog-card-post-title">{title}</p>
    </div><!-- /.c-blog-card-content -->
  </a>
</article>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .c-blog-card-link {
    display: flex;
    align-items: center;
    gap: min(20px, calc(20 var(--vw-sp)));
    line-height: 1.5;
  }

  .c-blog-card-image {
    flex: 0 0 100px;
  }

  .c-blog-card-content {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .c-blog-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
  }

  .c-blog-card-category {
    padding: 1px 12px 0;
    border-radius: 3px;
    border: 1px solid;
  }

  .c-blog-card-date {
    font-weight: 700;
  }

  .c-blog-card-post-title {
    font-weight: 700;
  }

  @include mq() {
    .c-blog-card-link {
      gap: 40px;
    }

    .c-blog-card-image {
      flex: 0 0 250px;
    }

    .c-blog-card-content {
      gap: 20px;
    }

    .c-blog-card-meta {
      gap: 40px;
      font-size: 14px;
    }

    .c-blog-card-category {
      padding: 2px 19px 1px;
    }
  }

  @media (any-hover: hover) {
    .c-blog-card {
      transition: color .3s ease;

      &:hover {
        color: var(--color-baby-pink);
      }
    }
  }
</style>
